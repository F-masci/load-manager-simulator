<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%replace(%thread){'.*\.([^.]+)\.main\(\)', '$1'}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Change level to DEBUG to see detailed job arrival and completion traces -->
    <logger name="it.pmcsn" level="INFO" />

    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
