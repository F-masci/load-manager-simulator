<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%-5level %logger{0} [%marker] - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="it.uniroma2.pmcsn" level="INFO" />

    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
